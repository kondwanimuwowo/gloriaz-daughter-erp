# Supabase Configuration (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Lenco Payment (required for Buy Now on finished goods)
# Get your keys from Lenco - https://lenco.co
NEXT_PUBLIC_LENCO_PUBLIC_KEY=
LENCO_API_SECRET_KEY=

# Supabase service role key (required for server-side payment verification)
SUPABASE_SERVICE_ROLE_KEY=

# Business contact details shown in footer (hidden if not set)
NEXT_PUBLIC_BUSINESS_ADDRESS=
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_BUSINESS_EMAIL=

# Social media profile URLs shown in footer (hidden if not set)
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_TWITTER=
