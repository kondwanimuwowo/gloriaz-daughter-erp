# Supabase Configuration (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# WhatsApp number for "Buy via WhatsApp" button (e.g. 2348001234567)
# Button is hidden if not set
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Business contact details shown in footer (hidden if not set)
NEXT_PUBLIC_BUSINESS_ADDRESS=
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_BUSINESS_EMAIL=

# Social media profile URLs shown in footer (hidden if not set)
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_TWITTER=
